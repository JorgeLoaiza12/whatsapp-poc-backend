# ── Database (Neon / Railway PostgreSQL) ──────────────────────────────────────
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL of the frontend (Railway service URL or custom domain)
# www and non-www variants are handled automatically
FRONTEND_URL=https://agen.cl

# ── Meta / WhatsApp Cloud API ─────────────────────────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
# Must match the verify token configured in Meta App Dashboard > Webhooks
META_WEBHOOK_VERIFY_TOKEN=your_custom_verify_token

# ── Server ────────────────────────────────────────────────────────────────────
# Railway injects PORT automatically — leave unset in Railway env vars
# PORT=3001   <- local dev only
